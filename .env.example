# Port na kojem se backend pokreće
PORT=5001

# Tajni ključ za JWT token
JWT_SECRET=aura_jwt_secret_key_2026

# Turso Cloud SQLite Database (Opciono: ostaviti prazno za lokalni SQLite fallback)
TURSO_DATABASE_URL=libsql://grcka-aura-username.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token_here

# Cloudinary nalog za otpremanje slika (Opciono: ostaviti prazno za lokalni /uploads folder)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Groq Cloud API Keys
GROQ_API_KEY=your_general_groq_api_key_here
PLANNER_GROQ_API_KEY=your_planner_groq_api_key_here
